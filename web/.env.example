NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# 로그인 없이 API를 관리자 권한으로 통과 (외부 사람에게 잠깐 보여줄 때만)
# 실서비스·공개 URL에서는 반드시 false 유지
NEXT_PUBLIC_BYPASS_AUTH=false
# 예: Vercel Preview 전용 테스트
# NEXT_PUBLIC_BYPASS_AUTH=true

# 배포된 사이트 루트 URL (끝에 / 없이). 관리 홈·학부모 링크 표시에 사용(없으면 Vercel이 주는 프로덕션 호스트 사용)
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
#
# 같은 Wi-Fi에서 폰으로 로컬 개발 서버 테스트 시 — ipconfig IPv4로 바꿔서 넣으면 학부모 링크 등이 폰 주소로 맞춰짐
# NEXT_PUBLIC_SITE_URL=http://192.168.0.10:3000
# ※ localhost/parents 는 본인 PC에서만 열립니다. 외부 테스트는 Vercel 배포 주소 + /parents (관리 화면에 자동 표시)
# ※ Vercel에서 Deployment Protection 끄기 — 켜 두면 다른 사람 폰에서 막힐 수 있음

# --- 다른 사람에게 URL로 테스트시키기 (Vercel 예시) ---
# 1) GitHub에 푸시 후 Vercel에서 Import → Root Directory가 web이면 web 폴더 지정
# 2) Environment Variables에 이 파일의 키들 복사 (SUPABASE_SERVICE_ROLE_KEY 포함)
# 3) NEXT_PUBLIC_BYPASS_AUTH=true 로 Preview/Production 배포 (테스트 끝나면 false)
# 4) 학부모 페이지만 볼 사람: /parents 링크만 공유
# 5) 관리 화면까지 볼 사람: 배포 URL 루트(/) 공유 — BYPASS 시 로그인 없이 메뉴·API 동작
# 6) 실제 로그인 테스트 시: BYPASS 끄고 Supabase → Authentication → URL Configuration에
#    Site URL 및 Redirect URLs에 https://배포주소 를 추가

# Server-side only. Never expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: protect Vercel cron endpoints
CRON_SECRET=YOUR_CRON_SECRET

# Optional: protect Naver webhook endpoint
NAVER_WEBHOOK_SECRET=YOUR_NAVER_WEBHOOK_SECRET

# Optional: protect Kakao webhook endpoint
KAKAO_WEBHOOK_SECRET=YOUR_KAKAO_WEBHOOK_SECRET
KVA_NOTICE_URL=https://www.kva.or.kr/
INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_INSTAGRAM_BUSINESS_ACCOUNT_ID
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_ACCESS_TOKEN
INSTAGRAM_PAGE_ID=YOUR_INSTAGRAM_PAGE_ID

# 인포뱅크(Bizgo) 카카오톡 발송 연동
INFOBANK_BASE_URL=https://omni.ibapi.kr
INFOBANK_CLIENT_ID=YOUR_INFOBANK_CLIENT_ID
INFOBANK_PASSWORD=YOUR_INFOBANK_PASSWORD
INFOBANK_SENDER_KEY=YOUR_INFOBANK_SENDER_KEY

# FAV2 신청 폼 연동 웹훅 인증값 (선택)
FAV_WEBHOOK_SECRET=

# Optional: 홈 AI 질문의 자연어 의도 분류 (없으면 키워드 규칙만 사용)
OPENAI_API_KEY=
# Optional: 기본 gpt-4o-mini
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
# 답변 문장 다듬기 전용 (미설정 시 OPENAI_ASSISTANT_MODEL 사용)
OPENAI_POLISH_MODEL=gpt-4o-mini
# true면 DB 원문 그대로만 반환
OPENAI_DISABLE_POLISH=false

# 웹 푸시 (web-push generate-vapid-keys 로 생성)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# contact for VAPID (mailto: 또는 https:)
VAPID_MAILTO=mailto:you@example.com
